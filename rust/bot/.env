# Claude API Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required)
ANTHROPIC_API_KEY=your-api-key-here

# API Base URL (optional, defaults to https://api.anthropic.com)
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model to use (optional, defaults to claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Maximum tokens per response (optional)
ANTHROPIC_MAX_TOKENS=4096

# Temperature (optional, defaults to 1.0)
ANTHROPIC_TEMPERATURE=1.0